// Package connectivity provides AWS SDK client for VPC endpoints
package connectivity

import (
	"context"
	"fmt"
	"time"

	"github.com/aws/aws-sdk-go-v2/aws"
	"github.com/aws/aws-sdk-go-v2/config"
	"github.com/aws/aws-sdk-go-v2/credentials"
	"github.com/aws/aws-sdk-go-v2/service/ec2"
	"github.com/aws/aws-sdk-go-v2/service/ec2/types"
)

// AWSCredentials holds AWS authentication details
type AWSCredentials struct {
	AccessKeyID     string `json:"accessKeyId"`
	SecretAccessKey string `json:"secretAccessKey"`
	SessionToken    string `json:"sessionToken,omitempty"`
	Region          string `json:"region"`
}

// VPCEndpointClient wraps AWS EC2 client for VPC endpoint operations
type VPCEndpointClient struct {
	ec2Client *ec2.Client
	region    string
}

// NewVPCEndpointClient creates a new AWS-based VPC endpoint client
func NewVPCEndpointClient(ctx context.Context, creds AWSCredentials) (*VPCEndpointClient, error) {
	if creds.Region == "" {
		return nil, fmt.Errorf("region is required in credentials")
	}

	fmt.Printf("DEBUG: Creating VPC endpoint client for region: %s\n", creds.Region)
	if len(creds.AccessKeyID) > 0 {
		fmt.Printf("DEBUG: AccessKeyID: %s\n", creds.AccessKeyID[:min(10, len(creds.AccessKeyID))])
	} else {
		fmt.Printf("DEBUG: AccessKeyID: (empty)\n")
	}
	fmt.Printf("DEBUG: SessionToken present: %v (length: %d)\n", len(creds.SessionToken) > 0, len(creds.SessionToken))

	// Create credentials provider
	credProvider := credentials.NewStaticCredentialsProvider(
		creds.AccessKeyID,
		creds.SecretAccessKey,
		creds.SessionToken,
	)

	// Verify credentials work
	credValue, err := credProvider.Retrieve(ctx)
	if err != nil {
		fmt.Printf("DEBUG: Failed to retrieve credentials: %v\n", err)
		return nil, fmt.Errorf("failed to retrieve credentials: %w", err)
	}
	fmt.Printf("DEBUG: Credentials retrieved successfully\n")
	if len(credValue.AccessKeyID) > 0 {
		fmt.Printf("DEBUG: AccessKey from provider: %s\n", credValue.AccessKeyID[:min(10, len(credValue.AccessKeyID))])
	}

	// Build explicit endpoint URL
	endpointURL := fmt.Sprintf("https://ec2.%s.amazonaws.com", creds.Region)
	fmt.Printf("DEBUG: Using explicit endpoint URL: %s\n", endpointURL)

	// Resolver compatible with current SDK versions
	resolver := aws.EndpointResolverWithOptionsFunc(
		func(service, region string, options ...interface{}) (aws.Endpoint, error) {
			// Handle EC2 service
			if service == ec2.ServiceID {
				fmt.Printf("DEBUG: Resolving EC2 endpoint for region=%s -> %s\n", region, endpointURL)
				return aws.Endpoint{
					URL:           endpointURL,
					SigningRegion: creds.Region,
					Source:        aws.EndpointSourceCustom,
				}, nil
			}
			// Fall back to default for other services
			return aws.Endpoint{}, &aws.EndpointNotFoundError{}
		},
	)

	// Load config with EndpointResolverWithOptions
	cfg, err := config.LoadDefaultConfig(ctx,
		config.WithRegion(creds.Region),
		config.WithCredentialsProvider(credProvider),
		config.WithEndpointResolverWithOptions(resolver),
	)
	if err != nil {
		fmt.Printf("DEBUG: Failed to load config: %v\n", err)
		return nil, fmt.Errorf("failed to load AWS config: %w", err)
	}

	fmt.Printf("DEBUG: AWS config loaded successfully\n")
	fmt.Printf("DEBUG: Config Region: %s\n", cfg.Region)

	// Create EC2 client
	ec2Client := ec2.NewFromConfig(cfg)

	fmt.Printf("DEBUG: EC2 client created successfully\n")
	fmt.Printf("  Region: %s\n", creds.Region)
	fmt.Printf("  Endpoint: %s\n", endpointURL)
	if len(creds.AccessKeyID) > 0 {
		fmt.Printf("  AccessKeyID: %s...\n", creds.AccessKeyID[:min(10, len(creds.AccessKeyID))])
	}

	return &VPCEndpointClient{
		ec2Client: ec2Client,
		region:    creds.Region,
	}, nil
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}

// CreateVPCEndpointInput mirrors AWS SDK input structure
type CreateVPCEndpointInput struct {
	VpcID             string
	ServiceName       string
	SubnetIDs         []string
	SecurityGroupIDs  []string
	VPCEndpointType   string // Interface or Gateway
	IPAddressType     string // ipv4 or ipv6
	PolicyDocument    string // Optional: restrictive policy
	PrivateDNSEnabled bool   // Enable private DNS
	TagSpecifications map[string]string
}

// VPCEndpointOutput represents the created VPC endpoint
type VPCEndpointOutput struct {
	VPCEndpointID     string
	ServiceName       string
	State             string
	VPCEndpointType   string
	SubnetIDs         []string
	GroupIDs          []string
	PrivateDNSName    string
	NetworkInterfaces []NetworkInterface
}

// NetworkInterface represents ENI details
type NetworkInterface struct {
	NetworkInterfaceID string
	SubnetID           string
	PrivateIP          string
	Status             string
}

// CreateVPCEndpoint creates an AWS VPC endpoint using AWS SDK
func (c *VPCEndpointClient) CreateVPCEndpoint(ctx context.Context, input CreateVPCEndpointInput) (*VPCEndpointOutput, error) {
	// Validate required fields
	if input.VpcID == "" || input.ServiceName == "" {
		return nil, fmt.Errorf("VPC ID and Service Name are required")
	}

	// ===== DEBUG SECTION =====
	fmt.Printf("\n========== DEBUG CreateVPCEndpoint ==========\n")
	fmt.Printf("Input parameters:\n")
	fmt.Printf("  VpcID: %s\n", input.VpcID)
	fmt.Printf("  ServiceName: %s\n", input.ServiceName)
	fmt.Printf("  VpcEndpointType: %s\n", input.VPCEndpointType)
	fmt.Printf("  SubnetIDs: %v\n", input.SubnetIDs)
	fmt.Printf("  SecurityGroupIDs: %v\n", input.SecurityGroupIDs)
	fmt.Printf("Client info:\n")
	fmt.Printf("  Region: %s\n", c.region)
	fmt.Printf("  EC2Client: %v\n", c.ec2Client != nil)
	fmt.Printf("==========================================\n\n")

	// Convert string type to AWS enum type
	endpointType := types.VpcEndpointTypeInterface
	if input.VPCEndpointType == "Gateway" {
		endpointType = types.VpcEndpointTypeGateway
	}

	// Build request with optional fields
	req := &ec2.CreateVpcEndpointInput{
		VpcId:             aws.String(input.VpcID),
		ServiceName:       aws.String(input.ServiceName),
		VpcEndpointType:   endpointType,
		SubnetIds:         input.SubnetIDs,
		SecurityGroupIds:  input.SecurityGroupIDs,
		TagSpecifications: buildTagSpecifications(input.TagSpecifications),
	}

	// ===== LOG THE REQUEST =====
	fmt.Printf("\n========== AWS Request ==========\n")
	fmt.Printf("  VpcId: %s\n", *req.VpcId)
	fmt.Printf("  ServiceName: %s\n", *req.ServiceName)
	fmt.Printf("  VpcEndpointType: %v\n", req.VpcEndpointType)
	fmt.Printf("  SubnetIds: %v\n", req.SubnetIds)
	fmt.Printf("  SecurityGroupIds: %v\n", req.SecurityGroupIds)
	fmt.Printf("==================================\n\n")

	// Add optional policy document
	if input.PolicyDocument != "" {
		req.PolicyDocument = aws.String(input.PolicyDocument)
	}

	// Add private DNS settings for Interface endpoints
	if input.VPCEndpointType == "Interface" && input.PrivateDNSEnabled {
		req.PrivateDnsEnabled = aws.Bool(true)
	}

	// ===== CATCH THE ERROR WITH DETAILS =====
	fmt.Printf("Calling AWS CreateVpcEndpoint...\n")
	result, err := c.ec2Client.CreateVpcEndpoint(ctx, req)
	if err != nil {
		fmt.Printf("\n!!!!!! ERROR OCCURRED !!!!!\n")
		fmt.Printf("Error type: %T\n", err)
		fmt.Printf("Error message: %v\n", err)
		fmt.Printf("Error string: %s\n", err.Error())

		// Try to get more details about the error
		if aerr, ok := err.(interface{ ErrorCode() string }); ok {
			fmt.Printf("AWS Error Code: %s\n", aerr.ErrorCode())
		}

		fmt.Printf("!!!!!!!!!!!!!!!!!!!!!!!!!!\n\n")

		return nil, fmt.Errorf("failed to create VPC endpoint: %w", err)
	}

	// ===== LOG SUCCESS =====
	fmt.Printf("\n✅ VPC Endpoint created successfully!\n")
	fmt.Printf("  VpcEndpointId: %s\n", *result.VpcEndpoint.VpcEndpointId)
	fmt.Printf("  State: %v\n", result.VpcEndpoint.State)
	fmt.Printf("=====================================\n\n")

	// Transform AWS response to our model
	output := &VPCEndpointOutput{
		VPCEndpointID:   aws.ToString(result.VpcEndpoint.VpcEndpointId),
		ServiceName:     aws.ToString(result.VpcEndpoint.ServiceName),
		State:           string(result.VpcEndpoint.State),
		VPCEndpointType: string(result.VpcEndpoint.VpcEndpointType),
		SubnetIDs:       result.VpcEndpoint.SubnetIds,
		GroupIDs:        extractSecurityGroupIDs(result.VpcEndpoint.Groups),
	}

	// Extract network interface details if available
	if result.VpcEndpoint.NetworkInterfaceIds != nil {
		output.NetworkInterfaces = make([]NetworkInterface, len(result.VpcEndpoint.NetworkInterfaceIds))
		// Note: To get detailed ENI info, would need separate DescribeNetworkInterfaces call
	}

	return output, nil
}

// GetVPCEndpointStatus retrieves the current state of a VPC endpoint
func (c *VPCEndpointClient) GetVPCEndpointStatus(ctx context.Context, vpcEndpointID string) (*VPCEndpointOutput, error) {
	if vpcEndpointID == "" {
		return nil, fmt.Errorf("VPC endpoint ID is required")
	}

	result, err := c.ec2Client.DescribeVpcEndpoints(ctx, &ec2.DescribeVpcEndpointsInput{
		VpcEndpointIds: []string{vpcEndpointID},
	})
	if err != nil {
		return nil, fmt.Errorf("failed to describe VPC endpoint: %w", err)
	}

	if len(result.VpcEndpoints) == 0 {
		return nil, fmt.Errorf("VPC endpoint not found: %s", vpcEndpointID)
	}

	vpce := result.VpcEndpoints[0]
	output := &VPCEndpointOutput{
		VPCEndpointID:   aws.ToString(vpce.VpcEndpointId),
		ServiceName:     aws.ToString(vpce.ServiceName),
		State:           string(vpce.State),
		VPCEndpointType: string(vpce.VpcEndpointType),
		SubnetIDs:       vpce.SubnetIds,
		GroupIDs:        extractSecurityGroupIDs(vpce.Groups),
	}

	// Extract private DNS name for Interface endpoints
	if vpce.DnsEntries != nil && len(vpce.DnsEntries) > 0 {
		output.PrivateDNSName = aws.ToString(vpce.DnsEntries[0].DnsName)
	}

	// Transform network interface info
	output.NetworkInterfaces = make([]NetworkInterface, len(vpce.NetworkInterfaceIds))
	for i, eniID := range vpce.NetworkInterfaceIds {
		output.NetworkInterfaces[i].NetworkInterfaceID = eniID
	}

	return output, nil
}

// DeleteVPCEndpoint deletes a VPC endpoint
func (c *VPCEndpointClient) DeleteVPCEndpoint(ctx context.Context, vpcEndpointID string) error {
	if vpcEndpointID == "" {
		return fmt.Errorf("VPC endpoint ID is required")
	}

	_, err := c.ec2Client.DeleteVpcEndpoints(ctx, &ec2.DeleteVpcEndpointsInput{
		VpcEndpointIds: []string{vpcEndpointID},
	})
	if err != nil {
		return fmt.Errorf("failed to delete VPC endpoint: %w", err)
	}

	return nil
}

// ModifyVPCEndpointServiceConfiguration modifies VPC endpoint attributes
// Note: AWS VPC endpoints have limited modification capabilities
// This supports modifying security groups and subnet associations
func (c *VPCEndpointClient) ModifyVPCEndpointServiceConfiguration(ctx context.Context, vpcEndpointID string, securityGroupIDs []string) error {
	if vpcEndpointID == "" {
		return fmt.Errorf("VPC endpoint ID is required")
	}

	// Build modify request - only supports limited fields
	req := &ec2.ModifyVpcEndpointInput{
		VpcEndpointId:       aws.String(vpcEndpointID),
		AddSecurityGroupIds: securityGroupIDs,
	}

	_, err := c.ec2Client.ModifyVpcEndpoint(ctx, req)
	if err != nil {
		return fmt.Errorf("failed to modify VPC endpoint: %w", err)
	}

	return nil
}

// buildTagSpecifications creates AWS tag specifications from map
func buildTagSpecifications(tags map[string]string) []types.TagSpecification {
	if len(tags) == 0 {
		return nil
	}

	tagList := make([]types.Tag, 0, len(tags))
	for key, value := range tags {
		tagList = append(tagList, types.Tag{
			Key:   aws.String(key),
			Value: aws.String(value),
		})
	}

	return []types.TagSpecification{
		{
			ResourceType: types.ResourceTypeVpcEndpoint,
			Tags:         tagList,
		},
	}
}

// extractSecurityGroupIDs converts SecurityGroupIdentifier slice to string slice
func extractSecurityGroupIDs(groups []types.SecurityGroupIdentifier) []string {
	if len(groups) == 0 {
		return []string{}
	}

	ids := make([]string, len(groups))
	for i, group := range groups {
		ids[i] = aws.ToString(group.GroupId)
	}
	return ids
}

// WaitForVPCEndpointAvailable waits for VPC endpoint to reach available state
func (c *VPCEndpointClient) WaitForVPCEndpointAvailable(ctx context.Context, vpcEndpointID string) error {
	maxAttempts := 120 // 10 minutes with 5 second intervals
	attempt := 0

	for attempt < maxAttempts {
		endpoint, err := c.GetVPCEndpointStatus(ctx, vpcEndpointID)
		if err != nil {
			return err
		}

		if endpoint.State == "available" {
			return nil
		}

		if endpoint.State == "failed" || endpoint.State == "deleted" {
			return fmt.Errorf("VPC endpoint entered terminal state: %s", endpoint.State)
		}

		// Sleep and retry
		select {
		case <-time.After(5 * time.Second):
			attempt++
		case <-ctx.Done():
			return ctx.Err()
		}
	}

	return fmt.Errorf("timeout waiting for VPC endpoint to become available")
}
